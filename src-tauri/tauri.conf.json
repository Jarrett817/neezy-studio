{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "neezy-studio",
  "version": "0.1.0",
  "identifier": "com.neezy.studio",
  "build": {
    "frontendDist": "../build/client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "bun run dev --host 127.0.0.1",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "neezy-studio",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "app"],
    "externalBin": [],
    "resources": [
      "resources/windows",
      "resources/macos"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
