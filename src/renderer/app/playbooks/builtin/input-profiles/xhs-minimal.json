{
  "id": "xhs-minimal",
  "version": 1,
  "capture": ["chips", "singleLineExtract", "form", "inheritPersona"],
  "fields": [
    {
      "key": "topic",
      "label": "选题或商品卖点",
      "type": "text",
      "required": true
    },
    {
      "key": "count",
      "label": "生成条数",
      "type": "number",
      "default": 3,
      "chips": [1, 3, 5],
      "chip": true
    },
    {
      "key": "tone",
      "label": "语气",
      "type": "enum",
      "options": ["口语", "专业", "治愈"],
      "default": "口语",
      "chip": true
    },
    {
      "key": "extra",
      "label": "补充说明",
      "type": "textarea",
      "required": false
    }
  ],
  "promptTemplate": "任务：围绕「{{topic}}」生成 {{count}} 条小红书笔记文案，语气：{{tone}}。\n\n账号人设摘要：\n{{persona}}\n\n可参考记忆：\n{{retrievedMemories}}\n\n用户补充：{{extra}}\n\n请输出 JSON 数组，每项含 title、body、tags（字符串数组）。不要输出其它文字。"
}
