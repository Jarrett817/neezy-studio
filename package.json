{
  "name": "neezy-studio",
  "private": true,
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "predev": "node scripts/free-dev-ports.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:inspect": "node scripts/db-inspect.mjs",
    "db:studio": "node scripts/db-studio.mjs",
    "db:path": "node scripts/resolve-app-database.mjs --print-path",
    "db:reset": "node scripts/reset-local-db.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix --fix-type exports,types,dependencies",
    "knip:clean": "knip --fix --fix-type exports,types,dependencies,files --allow-remove-files"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/sora": "^5.2.8",
    "@libsql/client": "^0.17.3",
    "@tanstack/react-query": "^5.100.11",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/extension-mention": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/html": "^3.24.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@tiptap/suggestion": "^3.25.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.4",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "node-llama-cpp": "^3.18.1",
    "pdf-parse": "^2.4.5",
    "pi-chrome": "0.15.27",
    "pi-permission-system": "^0.6.0",
    "pi-sandbox": "^0.4.3",
    "pi-textbrowser": "1.1.0",
    "pi-web-access": "^0.10.7",
    "playwright": "^1.60.0",
    "prosemirror-markdown": "^1.13.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "build": {
    "extraResources": [
      {
        "from": "resources/embeddings",
        "to": "embeddings",
        "filter": ["**/*.gguf"]
      }
    ]
  },
  "overrides": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@^0.78.0",
    "@mariozechner/pi-ai": "npm:@earendil-works/pi-ai@^0.78.0",
    "@mariozechner/pi-tui": "npm:@earendil-works/pi-tui@^0.78.0",
    "@mariozechner/pi-agent-core": "npm:@earendil-works/pi-agent-core@^0.78.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "6.0.0-beta.0",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.13",
    "vite-plugin-svgr": "^5.2.0"
  }
}
