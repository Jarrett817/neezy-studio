{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "os:default",
    "fs:default",
    "clipboard-manager:default",
    "process:default",
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-spawn",
    "log:default",
    "sql:default",
    "store:default",
    "http:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "taskkill",
          "cmd": "taskkill",
          "args": true
        }
      ]
    }
  ]
}
