{
  "name": "neezy-studio",
  "private": true,
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:clean": "node -e \"require('fs').rmSync('node_modules/.vite',{recursive:true,force:true});require('fs').rmSync('.react-router',{recursive:true,force:true});require('fs').rmSync('build',{recursive:true,force:true})\" && react-router dev",
    "electron:build": "tsc -p tsconfig.electron.json && node -e \"require('fs').copyFileSync('electron/runtime.package.json','dist-electron/package.json')\"",
    "electron:watch": "tsc -w -p tsconfig.electron.json",
    "electron:dev": "bun run electron:build && concurrently -k -n tsc,electron \"bun run electron:watch\" \"nodemon -q -w dist-electron -e js --delay 300ms --exec electron ./dist-electron/main.js --dev\"",
    "electron:rebuild": "electron-rebuild -f -w node-llama-cpp",
    "electron:start": "bun run build && bun run electron:build && electron ./dist-electron/main.js",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc && tsc -p tsconfig.electron.json",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "node-llama-cpp": "^3.18.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@huggingface/hub": "^2.12.0",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@tanstack/react-query": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.39.0",
    "input-otp": "^1.4.2",
    "isbot": "^5.1.40",
    "lucide-react": "^1.16.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-markdown": "^10.1.0",
    "react-router": "7.15.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.13",
    "vite-plugin-svgr": "^5.2.0"
  }
}
